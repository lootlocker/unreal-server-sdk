# Doxyfile — LootLocker Unreal Server SDK
# Run from the repo root:  doxygen .doxygen/Doxyfile
# All relative paths are resolved from the working directory where doxygen is invoked.

#---------------------------------------------------------------------------
# Project
#---------------------------------------------------------------------------
PROJECT_NAME           = "LootLocker Unreal Server SDK"
PROJECT_BRIEF          = "Server-side backend SDK for Unreal Engine"
PROJECT_LOGO           = .doxygen/images/lootlocker-logo.png
OUTPUT_DIRECTORY       = docs

#---------------------------------------------------------------------------
# Build options
#---------------------------------------------------------------------------
EXTRACT_ALL = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
HIDE_UNDOC_MEMBERS     = YES
HIDE_UNDOC_CLASSES     = NO
INTERNAL_DOCS          = NO
JAVADOC_AUTOBRIEF      = YES
OPTIMIZE_OUTPUT_FOR_C = YES
WARN_AS_ERROR          = NO

#---------------------------------------------------------------------------
# Input
#---------------------------------------------------------------------------
INPUT                  = LootLockerServerSDK/Source/LootLockerServerSDK/Public \
                         .doxygen/groups.dox \
                         .doxygen/mainpage.md
RECURSIVE              = YES
FILE_PATTERNS          = *.h *.dox *.md
# Facade classes — the Blueprint interface is excluded; the C++ interface is
# included so its documented methods appear in the feature groups.
# The other files below are internal implementation details not part of the
# public SDK surface.
EXCLUDE                = LootLockerServerSDK/Source/LootLockerServerSDK/Public/LootLockerServerForBlueprints.h \
                         LootLockerServerSDK/Source/LootLockerServerSDK/Public/LootLockerServerHttpClient.h \
                         LootLockerServerSDK/Source/LootLockerServerSDK/Public/LootLockerServerEndpoints.h \
                         LootLockerServerSDK/Source/LootLockerServerSDK/Public/LootLockerServerLogger.h \
                         LootLockerServerSDK/Source/LootLockerServerSDK/Public/LootLockerServerLogLevel.h \
                         LootLockerServerSDK/Source/LootLockerServerSDK/Public/LootLockerServerPersistedState.h \
                         LootLockerServerSDK/Source/LootLockerServerSDK/Public/LootLockerServerStateData.h \
                         LootLockerServerSDK/Source/LootLockerServerSDK/Public/LootLockerServerSDK.h
USE_MDFILE_AS_MAINPAGE = .doxygen/mainpage.md
IMAGE_PATH             = .doxygen/images

#---------------------------------------------------------------------------
# Unreal Engine macro expansion
# Strip UE reflection macros so Doxygen sees clean C++ types.
#---------------------------------------------------------------------------
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO
PREDEFINED             = GENERATED_BODY()= \
                         UCLASS(...)= \
                         USTRUCT(...)= \
                         UENUM(...)= \
                         UFUNCTION(...)= \
                         UPROPERTY(...)= \
                         UINTERFACE(...)= \
                         LOOTLOCKERSERVERSDK_API= \
                         UMETA(...)= \
                         DECLARE_LOG_CATEGORY_EXTERN(...)= \
                         "DECLARE_DELEGATE_OneParam(Name,T1)=typedef void (*Name)(T1)" \
                         "DECLARE_DELEGATE_TwoParams(Name,T1,T2)=typedef void (*Name)(T1,T2)" \
                         "DECLARE_DELEGATE_ThreeParams(Name,T1,T2,T3)=typedef void (*Name)(T1,T2,T3)" \
                         "DECLARE_DELEGATE_FourParams(Name,T1,T2,T3,T4)=typedef void (*Name)(T1,T2,T3,T4)" \
                         "DECLARE_MULTICAST_DELEGATE_OneParam(Name,T1)=typedef void (*Name)(T1)" \
                         "DECLARE_MULTICAST_DELEGATE_TwoParams(Name,T1,T2)=typedef void (*Name)(T1,T2)" \
                         "DECLARE_DYNAMIC_MULTICAST_DELEGATE_OneParam(Name,T1,T1Name)=typedef void (*Name)(T1)"

#---------------------------------------------------------------------------
# HTML output
#---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_HEADER            = .doxygen/header.html
HTML_FOOTER            = .doxygen/footer.html
HTML_COLORSTYLE        = LIGHT
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = YES
LAYOUT_FILE            = .doxygen/DoxygenLayout.xml
HTML_EXTRA_STYLESHEET  = .doxygen/doxygen-awesome/doxygen-awesome.css \
                         .doxygen/doxygen-awesome/doxygen-awesome-sidebar-only.css \
                         .doxygen/custom-layout-fixes.css \
                         .doxygen/lootlocker-theme.css
HTML_EXTRA_FILES       = .doxygen/images/lootlocker-logo.png \
                         .doxygen/nav-customization.js

#---------------------------------------------------------------------------
# Disable unused outputs
#---------------------------------------------------------------------------
GENERATE_LATEX         = NO
SOURCE_BROWSER         = NO
SHOW_USED_FILES        = NO
